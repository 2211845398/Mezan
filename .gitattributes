# Auto-detect text files and normalize line endings to LF in the repository.
# On checkout, Git will convert to the OS-native line ending (CRLF on Windows).
* text=auto

# Force LF for files that run inside Linux containers — CRLF will break them.
*.sh text eol=lf
*.bash text eol=lf
Dockerfile* text eol=lf
docker-compose*.yml text eol=lf

# Force LF for Python source and config files (cross-platform consistency).
*.py text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf

# Force CRLF for Windows-specific scripts.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Mark binary files so Git never tries to diff or merge them.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
*.zip binary
*.gz binary
*.tar binary
