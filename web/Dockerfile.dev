FROM node:22-bookworm-slim

ENV PNPM_HOME=/root/.pnpm \
    PATH=/root/.pnpm:$PATH \
    NODE_ENV=development \
    CHOKIDAR_USEPOLLING=true \
    WATCHPACK_POLLING=true

RUN corepack enable && corepack prepare pnpm@9 --activate

WORKDIR /app/web

# Install runs against a named volume at /app/web/node_modules so host ABI
# mismatches (Mac/Windows) never corrupt the Linux container's install tree.
# See docker-compose.web.yml for the volume wiring.

EXPOSE 5173

CMD ["sh", "-lc", "pnpm install --prefer-offline && pnpm dev --host 0.0.0.0 --port 5173"]
