# Base path the frontend uses to reach the backend. In dev this is proxied by
# Vite (see vite.config.ts server.proxy) so '/api/v1' stays same-origin for
# cookies. In staging/prod it is served from the same Nginx in front of the API.
VITE_API_BASE_URL=/api/v1

# Deployment target: one of 'dev' | 'staging' | 'prod'. Parsed by config/env.ts.
VITE_ENVIRONMENT=dev

# Optional Sentry DSN. Empty disables Sentry.
VITE_SENTRY_DSN=

# Optional PostHog project key.
VITE_POSTHOG_KEY=

# 'true' to swap API calls to MSW handlers (dev only).
VITE_ENABLE_MOCK_API=false

# Numeric locale for the app. 'ar-EG' (Eastern Arabic numerals) is the default
# per WEB_FRONTEND_PLAN §6.3. Set 'ar-SA' to use Hindu-Arabic numerals instead.
VITE_LOCALE_NUMBERS=ar-EG

# Target URL used by the Vite dev proxy to reach the backend.
# Host defaults: http://localhost:8000
# Docker defaults (set by docker-compose.web.yml): http://api:8000
VITE_API_PROXY_TARGET=http://localhost:8000

# Source for `pnpm codegen`. Default on host is http://localhost:8000, inside
# the docker 'web' container it is http://api:8000 (set by compose file).
OPENAPI_URL=http://localhost:8000/openapi.json
